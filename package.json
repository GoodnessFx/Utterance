{
  "name": "anchorcast",
  "version": "1.4.0",
  "description": "AI-powered worship presentation, sermon transcript and Bible casting app for churches",
  "main": "src/main.js",
  "author": "AnchorCast",
  "license": "MIT",
  "scripts": {
    "web": "node server.js",
    "start": "electron .",
    "dev": "electron . --dev",
    "build:win:full": "electron-builder --config electron-builder-win-full.json --publish never",
    "build:win:light": "electron-builder --config electron-builder-win-light.json --publish never",
    "build:mac:full:arm": "electron-builder --config electron-builder-mac-full.json --arm64 --publish never",
    "build:mac:full:x64": "electron-builder --config electron-builder-mac-full.json --x64 --publish never",
    "build:mac:light:arm": "electron-builder --config electron-builder-mac-light.json --arm64 --publish never",
    "build:mac:light:x64": "electron-builder --config electron-builder-mac-light.json --x64 --publish never",
    "build:win": "npm run build:win:full && npm run build:win:light",
    "build:mac": "npm run build:mac:full:arm && npm run build:mac:light:arm",
    "build:linux": "electron-builder --linux",
    "build": "electron-builder --win --mac",
    "pack": "electron-builder --dir",
    "prepare:build:win": "node scripts/prepare-build.js --win",
    "prepare:build:mac": "node scripts/prepare-build.js --mac",
    "prebuild:win:full": "npm run prepare:build:win",
    "prebuild:win:light": "npm run prepare:build:win",
    "prebuild:mac:full:arm": "npm run prepare:build:mac",
    "prebuild:mac:full:x64": "npm run prepare:build:mac",
    "prebuild:mac:light:arm": "npm run prepare:build:mac",
    "prebuild:mac:light:x64": "npm run prepare:build:mac",
    "generate-license": "node generate-license.js",
    "generate": "node generate.js",
    "build:timer": "electron-builder --config electron-builder-timer.json --win",
    "start:timer": "electron src/timer-main.js",
    "build:win:update": "electron-builder --config electron-builder-win-update.json",
    "build:mac:update:arm": "electron-builder --config electron-builder-mac-update-arm.json",
    "build:mac:update:x64": "electron-builder --config electron-builder-mac-update-x64.json",
    "build:updates": "npm run build:update:win && npm run build:update:mac",
    "build:update:win": "npm run build:win:update",
    "build:update:mac": "npm run build:mac:update:arm && npm run build:mac:update:x64",
    "audit": "npm audit",
    "audit:fix": "npm audit fix"
  },
  "dependencies": {
    "electron-updater": "^6.3.9",
    "express": "^5.2.1"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^24.13.3"
  }
}